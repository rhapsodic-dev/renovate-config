{
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":maintainLockFilesWeekly",
    ":semanticCommitTypeAll(chore)"
  ],
  "rangeStrategy": "bump",
  "minimumReleaseAge": "14 days",
  "npm": {
    "commitMessageTopic": "{{prettyDepType}} {{depName}}"
  },
  "schedule": [
    "on Monday"
  ],
  "packageRules": [
    {
      "groupName": "rhapsodic packages",
      "groupSlug": "rhapsodic",
      "matchPackageNames": ["@rhapsodic/*"],
      "minimumReleaseAge": "0 days",
      "schedule": ["* * * * *"]
    },
    {
      "matchPackageNames": ["nuxt"],
      "minimumReleaseAge": "0 days"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "minimumReleaseAge": "0 days"
  }
}
